ll":{"duration":0.023847,"end_time":"2026-05-13T09:11:17.275468+00:00","exception":false,"start_time":"2026-05-13T09:11:17.251621+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["query_uplift = \"\"\"\n","\n","WITH conversion_rates AS (\n","\n","    SELECT\n","        Location,\n","        [Group],\n","\n","        COUNT(*) AS user_count,\n","\n","        SUM(\n","            CASE\n","                WHEN Conversion = 'Yes'\n","                THEN 1\n","                ELSE 0\n","            END\n","        ) * 1.0 / COUNT(*) AS conversion_rate\n","\n","    FROM ab_test\n","\n","    GROUP BY\n","        Location,\n","        [Group]\n","),\n","\n","location_uplift AS (\n","\n","    SELECT\n","        a.Location,\n","\n","        ROUND(a.conversion_rate * 100, 2) AS conversion_A,\n","        ROUND(b.conversion_rate * 100, 2) AS conversion_B,\n","\n","        ROUND(\n","            (\n","                (b.conversion_rate - a.conversion_rate)\n","                / a.conversion_rate\n","            ) * 100,\n","            2\n","        ) AS uplift_percent\n","\n","    FROM conversion_rates a\n","\n","    JOIN conversion_rates b\n","        ON a.Location = b.Location\n","\n","    WHERE\n","        a.[Group] = 'A'\n","        AND b.[Group] = 'B'\n","),\n","\n","overall_uplift AS (\n","\n","    SELECT\n","        'Overall' AS Location,\n","\n","        ROUND(\n","            MAX(CASE WHEN [Group] = 'A' THEN conversion_rate END) * 100,\n","            2\n","        ) AS conversion_A,\n","\n","        ROUND(\n","            MAX(CASE WHEN [Group] = 'B' THEN conversion_rate END) * 100,\n","            2\n","        ) AS conversion_B,\n","\n","        ROUND(\n","            (\n","                (\n","                    MAX(CASE WHEN [Group] = 'B' THEN conversion_rate END)\n","                    -\n","                    MAX(CASE WHEN [Group] = 'A' THEN conversion_rate END)\n","                )\n","                /\n","                MAX(CASE WHEN [Group]